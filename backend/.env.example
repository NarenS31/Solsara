# ===========================================
# Solsara Backend Environment Variables
# ===========================================
# Copy to backend/.env for local development.
# In production (e.g., Railway), set these in platform env vars.

# -------------------------------------------
# App / Core
# -------------------------------------------
# Environment name: development | staging | production
APP_ENV=development

# App secret used by backend security/session-related logic
SECRET_KEY=change-me-to-a-long-random-secret

# Frontend base URL used for OAuth redirect targets and links
FRONTEND_URL=http://localhost:3000

# Enable local dev shortcuts (e.g., fake review mode in some services)
DEV_MODE=false

# CORS allowed origins (JSON-style list string for pydantic parsing)
ALLOWED_ORIGINS=["http://localhost:3000","https://solsara.vercel.app","https://solsara.ai","https://www.solsara.ai"]

# -------------------------------------------
# Supabase
# -------------------------------------------
# Supabase project URL
SUPABASE_URL=https://your-project.supabase.co

# Supabase service key used by backend server operations
SUPABASE_KEY=your-supabase-service-key

# -------------------------------------------
# Google OAuth / Google Business Profile
# -------------------------------------------
# OAuth client credentials from Google Cloud Console
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Must match authorized redirect URI in Google Console
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/callback

# -------------------------------------------
# LLM Providers
# -------------------------------------------
# Used by backend demo route (OpenAI)
OPENAI_API_KEY=your-openai-api-key

# Used by core review reply generation in backend/services/llm.py (Claude)
ANTHROPIC_API_KEY=your-anthropic-api-key

# -------------------------------------------
# Stripe Billing
# -------------------------------------------
# Stripe secret API key
STRIPE_SECRET_KEY=sk_test_or_live_value

# Stripe webhook signing secret for /webhooks/stripe
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Stripe recurring price ID used when creating checkout sessions
STRIPE_PRICE_ID=price_xxx

# -------------------------------------------
# Email (Resend)
# -------------------------------------------
# API key for sending alerts and weekly summaries
RESEND_API_KEY=re_xxx

# -------------------------------------------
# Twilio (Missed Call Net)
# -------------------------------------------
# Twilio account credentials
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token

# Public backend base URL used to build Twilio webhook URLs
# Example local tunnel: https://your-ngrok-subdomain.ngrok.io
RAILWAY_URL=http://localhost:8000
